{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "nonprod"
    },
    "location": {
      "value": "eastus"
    },
    "containerImage": {
      "value": "ghcr.io/eslutz/gifforge-backend:latest"
    },
    "publicBaseUrl": {
      "value": ""
    },
    "sqlServer": {
      "value": "ericslutz-dev-db.database.windows.net"
    },
    "sqlDatabase": {
      "value": "ericslutz.dev.db"
    },
    "appleIdTokenAudiences": {
      "value": "dev.ericslutz.gifforge"
    },
    "appStoreBundleId": {
      "value": "dev.ericslutz.gifforge"
    },
    "appStoreJwsRootCertificatePem": {
      "value": ""
    },
    "minReplicas": {
      "value": 0
    },
    "maxReplicas": {
      "value": 5
    },
    "generationJobRetentionHours": {
      "value": 24
    },
    "temporaryBlobRetentionDays": {
      "value": 2
    },
    "retentionCleanupIntervalMinutes": {
      "value": 360
    },
    "retentionCleanupBatchSize": {
      "value": 100
    }
  }
}
